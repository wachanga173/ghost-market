# Ghost Market Environment Configuration

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://rtvumsbcqxnqboosytgn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Ethereum Configuration
NEXT_PUBLIC_INFURA_API_KEY=your_infura_api_key_here
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Smart Contract Addresses
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PAYMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Network Configuration
NEXT_PUBLIC_ETHEREUM_CHAIN_ID=1
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/your-api-key

# IPFS Configuration
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
NEXT_PUBLIC_IPFS_API_URL=https://ipfs.infura.io:5001

# Gun.js Peers
NEXT_PUBLIC_GUN_PEERS_1=https://gun-manhattan.herokuapp.com/gun
NEXT_PUBLIC_GUN_PEERS_2=https://gun-us-east-1.herokuapp.com/gun
NEXT_PUBLIC_GUN_PEERS_3=wss://gun.react.shop/gun

# Application Configuration
NEXT_PUBLIC_APP_NAME=Ghost Market
NEXT_PUBLIC_APP_DESC=Decentralized P2P Freelance Marketplace
NEXT_PUBLIC_APP_URL=https://ghost-market.app

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true

# Development/Production
NODE_ENV=development
